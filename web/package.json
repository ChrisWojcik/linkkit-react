{
  "name": "linkkit-react-web",
  "version": "1.0.0",
  "description": "Frontend for a reddit clone",
  "private": true,
  "engines": {
    "node": "16.10.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "TZ='UTC' jest",
    "lint": "next lint --fix && stylelint '**/*.{css,scss}' --fix",
    "format": "prettier --write '**/*.{css,scss,js}'",
    "lint-staged": "lint-staged"
  },
  "dependencies": {
    "classnames": "^2.3.1",
    "final-form": "^4.20.4",
    "final-form-focus": "^1.1.2",
    "next": "12.0.3",
    "normalize.css": "^8.0.1",
    "prop-types": "^15.7.2",
    "react": "17.0.2",
    "react-dom": "17.0.2",
    "react-final-form": "^6.5.7",
    "react-query": "^3.32.3",
    "validator": "^13.7.0"
  },
  "devDependencies": {
    "babel-jest": "^27.3.1",
    "babel-plugin-inline-react-svg": "^2.0.1",
    "eslint": "<8.0.0",
    "eslint-config-next": "12.0.3",
    "eslint-config-prettier": "^8.3.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^27.3.1",
    "lint-staged": "^12.0.2",
    "prettier": "^2.4.1",
    "react-test-renderer": "^17.0.2",
    "sass": "^1.43.4",
    "stylelint": "^13.13.1",
    "stylelint-config-css-modules": "^2.3.0",
    "stylelint-config-idiomatic-order": "^8.1.0",
    "stylelint-config-prettier": "^8.0.2",
    "stylelint-config-sass-guidelines": "^8.0.0",
    "stylelint-config-standard": "^22.0.0"
  },
  "browserslist": [
    "defaults",
    "not IE 11"
  ],
  "lint-staged": {
    "*.js": [
      "eslint --cache",
      "prettier --check"
    ],
    "*.{css,scss}": [
      "stylelint",
      "prettier --check"
    ]
  }
}
